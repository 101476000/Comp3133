{
  "info": {
    "name": "Lab07 Express Users API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST /users",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "firstname",
              "value": "Test",
              "type": "text"
            },
            {
              "key": "lastname",
              "value": "User",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "http://localhost:3000/users",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["users"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Body contains expected message', function () {",
              "  pm.expect(pm.response.text()).to.include('POST received!');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
